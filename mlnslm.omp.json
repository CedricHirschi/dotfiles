{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "console_title_template": " {{ .Folder }} :: {{if .Root}}Admin{{end}}",
    "palette": {
        "main-bg": "#24283b",
        "terminal-red": "#f7768e",
        "pistachio-green": "#9ece6a",
        "terminal-green": "#73daca",
        "terminal-yellow": "#e0af68",
        "terminal-blue": "#7aa2f7",
        "celeste-blue": "#b4f9f8",
        "light-sky-blue": "#7dcfff",
        "terminal-white": "#c0caf5",
        "white-blue": "#a9b1d6",
        "blue-bell": "#9aa5ce",
        "pastal-grey": "#cfc9c2",
        "terminal-magenta": "#bb9af7",
        "blue-black": "#565f89",
        "terminal-black": "#414868",
        "t-background": "p:main-bg"
    },
    "blocks": [
        {
            "alignment": "left",
            "segments": [
                {
                    "type": "text",
                    "style": "plain",
                    "background": "transparent",
                    "foreground": "p:terminal-blue",
                    "template": ">"
                },
                {
                    "type": "path",
                    "style": "plain",
                    "background": "transparent",
                    "foreground": "p:terminal-magenta"
                },
                {
                    "foreground": "p:pastal-grey",
                    "style": "plain",
                    "template": "{{.Icon}}{{ if .WSL }} (WSL){{ end }}",
                    "type": "os"
                },
                {
                    "foreground": "white",
                    "options": {
                        "threshold": 0
                    },
                    "style": "plain",
                    "template": " {{ .FormattedMs }}",
                    "type": "executiontime"
                },
                {
                    "foreground": "p:pistachio-green",
                    "foreground_templates": [
                        "{{ if (.Error) }}p:terminal-red{{ end }}"
                    ],
                    "style": "plain",
                    "template": " [{{ .String }}]",
                    "options": {
                        "status_template": "{{ .Code }} ({{ reason .Code }})"
                    },
                    "type": "status"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "right",
            "segments": [
                {
                    "type": "python",
                    "style": "plain",
                    "foreground": "p:terminal-blue",
                    "template": "\uE235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "rust",
                    "style": "plain",
                    "foreground": "p:terminal-blue",
                    "template": "\uE7A8 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "go",
                    "style": "plain",
                    "foreground": "p:terminal-blue",
                    "template": "\uE627 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "node",
                    "style": "plain",
                    "foreground": "p:terminal-blue",
                    "template": "\uE718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} "
                },
                {
                    "type": "lua",
                    "style": "plain",
                    "foreground": "p:terminal-blue",
                    "template": "\uE620 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "dotnet",
                    "style": "plain",
                    "foreground": "p:terminal-blue",
                    "template": "\uE77F {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "cmake",
                    "style": "plain",
                    "foreground": "p:terminal-magenta",
                    "template": "\uE794 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "bun",
                    "style": "plain",
                    "foreground": "p:terminal-magenta",
                    "template": "\uE76F {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
                },
                {
                    "type": "claude",
                    "style": "plain",
                    "foreground": "p:terminal-magenta",
                    "template": "\uDB82\uDFC9 {{ .Model.DisplayName }} \uF2D0 {{ .TokenUsagePercent.Gauge }} "
                },
                {
                    "type": "git",
                    "style": "plain",
                    "foreground": "p:light-sky-blue",
                    "foreground_templates": [
                        "{{ if (.Staging.Changed) }}p:terminal-red{{ end }}",
                        "{{ if (.Working.Changed) }}p:terminal-yellow{{ end }}",
                        "{{ if and (gt .Ahead 0) (gt .Behind 0)}}p:light-sky-blue {{ end }}",
                        "{{ if gt .Ahead 0 }}p:terminal-blue{{ end }}",
                        "{{ if gt .Behind 0 }}p:celeste-blue{{ end }}"
                    ],
                    "template": "({{ .HEAD}})",
                    "options": {
                        "fetch_status": true,
                        "branch_icon": "\ue725 "
                    }
                },
                {
                    "type": "battery",
                    "style": "plain",
                    "foreground": "white",
                    "foreground_templates": [
                        "{{ if eq \"Charging\" .State.String }}p:terminal-green{{end}}",
                        "{{ if eq \"Discharging\" .State.String }}p:terminal-red{{ end }}"
                    ],
                    "template": " {{ .Percentage }}%",
                    "options": {
                        "display_error": true
                    }
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "foreground": "p:pistachio-green",
                    "style": "plain",
                    "template": "$",
                    "type": "text"
                }
            ],
            "type": "prompt"
        }
    ],
    "secondary_prompt": {
        "foreground": "p:pistachio-green",
        "style": "plain",
        "template": "$ ",
        "type": "text"
    },
    "transient_prompt": {
        "foreground": "p:pistachio-green",
        "style": "plain",
        "template": "$ ",
        "type": "text"
    },
    "final_space": true,
    "version": 4,
    "terminal_background": "p:t-background"
}